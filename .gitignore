# ---------------------------------------------------------------------------
# NEVER COMMIT RAW DATA OR PLAINTEXT BUILDS
#
# Anything committed stays in git history forever, even if deleted in a later
# commit. Removing it means rewriting history and force-pushing. Keep it out
# in the first place.
# ---------------------------------------------------------------------------

# Source data
*.parquet
*.xlsm
*.xlsx
*.csv
Payment/
Receive/

# The unencrypted build. Only docs/index.html (encrypted) is publishable.
ITRS_Dashboard.html
*.plain.html

# Never commit the passphrase
.env
*.secret
password.txt
passphrase.txt
*passphrase*.txt
*.key

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
~$*
.vscode/
.idea/

# Documentation is kept locally, not published
README.md
README_local_backup.md
docs/README.txt

# Plaintext data pack (contains names/TINs) - never commit
ITRS_data_pack.json

# Login accounts (passwords) - never commit
config/users.json
